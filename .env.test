# Environment
NODE_ENV=test

# Server
PORT=5001

# Database (use separate test database)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/intutive_fusion_test_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=test-secret-key
JWT_EXPIRES_IN=1h

# API Keys
SYSTEM_API_KEY=test-api-key

# Logging
LOG_LEVEL=error

# Rate Limiting (more permissive for tests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
