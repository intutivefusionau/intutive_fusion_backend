generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int      @id @default(autoincrement())
  name                String
  phone               String   @unique
  role                UserRole
  createdAt           DateTime @default(now())
  password            String
  medicalOfficerCases Case[]   @relation("MedicalOfficerRelation")
  doctorProfile       Doctor?
  patientProfile      Patient?
}

model Patient {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  patientCode String   @unique
  age         Int?
  gender      String?
  createdAt   DateTime @default(now())
  cases       Case[]
  user        User     @relation(fields: [userId], references: [id])
}

model Doctor {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  specialization String?
  createdAt      DateTime @default(now())
  cases          Case[]
  user           User     @relation(fields: [userId], references: [id])
}

model Case {
  id               Int         @id @default(autoincrement())
  patientId        Int
  doctorId         Int?
  medicalOfficerId Int?
  department       String?
  visitType        VisitType?
  reasonForVisit   String?
  status           CaseStatus  @default(NEW)
  createdAt        DateTime    @default(now())
  closedAt         DateTime?
  updatedAt        DateTime    @default(now()) @updatedAt
  doctor           Doctor?     @relation(fields: [doctorId], references: [id])
  medicalOfficer   User?       @relation("MedicalOfficerRelation", fields: [medicalOfficerId], references: [id])
  patient          Patient     @relation(fields: [patientId], references: [id])
  caseRecord       CaseRecord?
  files            File[]

  @@index([updatedAt])
}

model CaseRecord {
  id                           Int      @id @default(autoincrement())
  caseId                       Int      @unique
  intakeTranscript             String?
  doctorTranscript             String?
  symptomsJson                 Json?
  aiDiagnosisJson              Json?
  suggestedFormsJson           Json?
  formsJson                    Json?
  doctorNotes                  String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  caseSummary                  Json?
  consultationJobName          String?
  consultationTranscriptStatus String?
  followUpQuestions            Json?
  intakeJobName                String?
  intakeTranscriptStatus       String?
  case                         Case     @relation(fields: [caseId], references: [id])
}

model File {
  id        Int      @id @default(autoincrement())
  caseId    Int
  fileType  FileType
  fileUrl   String
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id])
}

enum UserRole {
  PATIENT
  DOCTOR
  MEDICAL_OFFICER
  RECEPTION
}

enum VisitType {
  OPD
  FOLLOW_UP
}

enum CaseStatus {
  NEW
  INTAKE_STARTED
  INTAKE_DONE
  WAITING_DOCTOR
  CONSULTATION_DONE
  COMPLETED
}

enum FileType {
  INTAKE_AUDIO
  DOCTOR_AUDIO
}
