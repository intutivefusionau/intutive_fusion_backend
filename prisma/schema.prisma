generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())

  patientProfile Patient?
  doctorProfile  Doctor?

  medicalOfficerCases Case[] @relation("MedicalOfficerRelation")
}

model Patient {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  patientCode String   @unique
  age         Int?
  gender      String?
  createdAt   DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  cases Case[]
}

model Doctor {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  specialization String?
  createdAt      DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  cases Case[]
}

model Case {
  id               Int        @id @default(autoincrement())
  patientId        Int
  doctorId         Int?
  medicalOfficerId Int?
  department       String?
  visitType        VisitType?
  reasonForVisit   String?
  status           CaseStatus @default(NEW)
  createdAt        DateTime   @default(now())
  closedAt         DateTime?

  patient        Patient @relation(fields: [patientId], references: [id])
  doctor         Doctor? @relation(fields: [doctorId], references: [id])
  medicalOfficer User?   @relation("MedicalOfficerRelation", fields: [medicalOfficerId], references: [id])

  caseRecord CaseRecord?
  files      File[]
}

model CaseRecord {
  id               Int      @id @default(autoincrement())
  caseId           Int      @unique
  intakeTranscript String?  @db.Text
  doctorTranscript String?  @db.Text
  symptomsJson     Json?
  aiDiagnosisJson  Json?
  formsJson        Json?
  doctorNotes      String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  case Case @relation(fields: [caseId], references: [id])
}

model File {
  id        Int      @id @default(autoincrement())
  caseId    Int
  fileType  FileType
  fileUrl   String
  createdAt DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id])
}

enum UserRole {
  PATIENT
  DOCTOR
  MEDICAL_OFFICER
}

enum VisitType {
  OPD
  FOLLOW_UP
}

enum CaseStatus {
  NEW
  INTAKE_STARTED
  INTAKE_DONE
  WAITING_DOCTOR
  CONSULTATION_DONE
  COMPLETED
}

enum FileType {
  INTAKE_AUDIO
  DOCTOR_AUDIO
}